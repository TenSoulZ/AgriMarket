# AgriMarket Production Env Var Checklist (Koyeb)
DEBUG=False
SECRET_KEY=  # Generate a cryptographically secure 50+ character key
ALLOWED_HOSTS=agrimarket-backend.koyeb.app  # Or custom domain

# Database (e.g. Koyeb Postgres / neon.tech / RDS)
# You can specify individual variables OR a single DATABASE_URL connection string:
DATABASE_URL=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Redis (e.g. Upstash Redis / AWS ElastiCache)
REDIS_URL=redis://:password@upstash-redis-endpoint:6379/0

# Paynow Zimbabwe
PAYNOW_INTEGRATION_ID=  # Real merchant integration ID
PAYNOW_INTEGRATION_KEY=  # Real merchant integration key
PAYNOW_RETURN_URL=https://agrimarket.co.zw/orders/return
PAYNOW_RESULT_URL=https://agrimarket-backend.koyeb.app/api/v1/payments/webhook/

# Africa's Talking (production username and API key)
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=

# AWS S3 Storage (af-south-1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=agrimarket-prod-bucket
AWS_S3_REGION_NAME=af-south-1

# Sentry SDK Error Tracking
SENTRY_DSN=https://sentry-dsn-url
